# Frontend Environment Variables

# =============================================================================
# Supabase Configuration (Required for Authentication)
# =============================================================================
# Get these from your Supabase project at: https://app.supabase.com/
# 1. Create a new Supabase project
# 2. Go to Settings > API
# 3. Copy the Project URL and Public API Key (anon key)

VITE_SUPABASE_URL=your-supabase-project-url.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# =============================================================================
# Google OAuth Configuration (Optional - for direct Google Sign-In)
# =============================================================================
# Note: Supabase handles Google OAuth, so you may not need this
# VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
